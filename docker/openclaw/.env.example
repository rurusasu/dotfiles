OPENCLAW_PORT=18789
OPENCLAW_UID=1000
OPENCLAW_GID=1000
# Use the Docker-specific config rendered by chezmoi (contains Telegram + /app/data paths)
OPENCLAW_CONFIG_FILE=${USERPROFILE}/.openclaw/openclaw.docker.json
TZ=Asia/Tokyo
# OPENAI_API_KEY=sk-...
# GitHub Fine-grained PAT for git operations inside the container.
# Store in 1Password: op://Personal/GitHub/pat-used-openclaw
# Handler.OpenClaw.ps1 populates this automatically if op CLI is signed in.
GITHUB_TOKEN=
# Gemini CLI authentication for ACP agent sessions (sessions_spawn agentId="gemini").
# Option A (OAuth): set GEMINI_CREDENTIALS_DIR to your host ~/.gemini directory.
#   Authenticate once on the host with: gemini
#   Then the container reuses those tokens automatically.
#   GEMINI_CREDENTIALS_DIR=${USERPROFILE}/.gemini
# Option B (API key): set GEMINI_API_KEY from Google AI Studio (no browser auth needed).
#   GEMINI_API_KEY=
