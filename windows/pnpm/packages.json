{
  "$schema": "https://json.schemastore.org/package.json",
  "description": "pnpm global packages to install on Windows",
  "globalPackages": [
    {
      "name": "@prisma/language-server",
      "verifyCommand": {
        "args": ["--version"],
        "command": "prisma-language-server"
      }
    },
    {
      "name": "@agentclientprotocol/claude-agent-acp",
      "verifyCommand": {
        "args": [],
        "command": "claude-agent-acp",
        "type": "commandExists"
      }
    },
    {
      "name": "@playwright/cli@0.1.13",
      "verifyCommand": {
        "args": ["--version"],
        "command": "playwright-cli"
      }
    },
    {
      "name": "playwright@1.60.0",
      "postInstallCommand": {
        "args": ["install", "chromium"],
        "command": "playwright",
        "timeoutSeconds": 600
      },
      "verifyCommand": {
        "args": ["--version"],
        "command": "playwright"
      }
    },
    {
      "name": "typescript-language-server",
      "verifyCommand": {
        "args": ["--version"],
        "command": "typescript-language-server"
      }
    },
    {
      "name": "typescript",
      "verifyCommand": {
        "args": ["--version"],
        "command": "tsc"
      }
    },
    {
      "installArgs": ["--allow-build=@github/keytar", "--allow-build=node-pty"],
      "name": "@google/gemini-cli",
      "verifyCommand": {
        "args": ["--version"],
        "command": "gemini"
      }
    }
  ]
}
