{
  "$schema": "https://json.schemastore.org/package.json",
  "description": "pnpm global packages to install on Windows",
  "globalPackages": [
    {
      "name": "@tobilu/qmd",
      "verifyCommand": {
        "args": ["status"],
        "command": "qmd"
      }
    },
    {
      "name": "@google/gemini-cli",
      "verifyCommand": {
        "args": ["--version"],
        "command": "gemini"
      }
    }
  ]
}
