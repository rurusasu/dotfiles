# safety.rules
# Global safety nets for OpenAI Codex CLI

# Prevent "rm -rf /" - exact root deletion
prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Recursively deleting the root directory is catastrophic.",
    match = ["rm -rf /"],
    not_match = ["rm -rf ./temp", "rm -rf /tmp/test"],
)
