{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
{{- if eq .chezmoi.os "windows" }}
            "command": "uv run --isolated --managed-python python \"{{ .chezmoi.homeDir | replace "\\" "/" }}/.codex/hooks/claude_permission_policy.py\"",
{{- else }}
            "command": "python3 \"{{ .chezmoi.homeDir | replace "\\" "/" }}/.codex/hooks/claude_permission_policy.py\"",
{{- end }}
            "timeout": 30,
            "statusMessage": "Checking Claude-aligned Bash policy"
          },
          {
            "type": "command",
{{- if eq .chezmoi.os "windows" }}
            "command": "uv run --isolated --managed-python python \"{{ .chezmoi.homeDir | replace "\\" "/" }}/.codex/hooks/deny_protected_branch_commit.py\"",
{{- else }}
            "command": "python3 \"{{ .chezmoi.homeDir | replace "\\" "/" }}/.codex/hooks/deny_protected_branch_commit.py\"",
{{- end }}
            "timeout": 30,
            "statusMessage": "Checking protected branch policy"
          }
        ]
      }
    ]
  }
}
