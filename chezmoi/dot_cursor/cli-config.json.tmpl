{
  "version": 1,
  "model": "auto",
  "editor": {
    "vimMode": false
  },
  "permissions": {
    "allow": ["Read(**/*)", "Write(**/*)", "Shell(*)"],
    "deny": [
      "Shell(sudo)",
      "Shell(curl)",
      "Shell(wget)",
      "Shell(rm)",
      "Read(.env*)",
      "Write(.env*)",
      "Read(secrets/**)",
      "Write(secrets/**)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*.key)",
      "Write(**/*.key)",
      "Write(pyproject.toml)",
      "Write(requirements.txt)",
      "Write(uv.lock)"
    ]
  },
  "network": {
    "useHttp1ForAgent": false
  },
  "attribution": {
    "attributeCommitsToAgent": true,
    "attributePRsToAgent": true
  },
  "mcpServers": {
{{- $first := true }}
{{- if hasKey . "mcp_servers" }}
{{- range .mcp_servers }}
{{- if has "cursor" .supports }}
{{- if not $first }},{{ end }}
{{- $first = false }}
    "{{ .name }}": {
{{- if and (hasKey . "url") (not (hasKey . "command")) }}
      "url": "{{ .url }}"
{{- else }}
      "command": "{{ .command }}",
      "args": [{{ range $i, $arg := .args }}{{ if $i }}, {{ end }}"{{ $arg }}"{{ end }}]
{{- end }}
{{- if hasKey . "env" }},
      "env": {
{{- $envFirst := true }}
{{- $hasOp := and (hasKey . "op_env") (lookPath "op") }}
{{- $opEnv := dict }}
{{- if hasKey . "op_env" }}{{ $opEnv = .op_env }}{{ end }}
{{- range $key, $value := .env }}
{{- if not $envFirst }},{{ end }}
{{- $envFirst = false }}
{{- if and $hasOp (hasKey $opEnv $key) }}
        "{{ $key }}": "{{ onepasswordRead (index $opEnv $key) }}"
{{- else }}
        "{{ $key }}": "{{ $value }}"
{{- end }}
{{- end }}
      }
{{- end }}
    }
{{- end }}
{{- end }}
{{- end }}
  }
}
