#!/usr/bin/env bash
set -euo pipefail

check_environment() {
    if [[ "$(uname -s)" != "Linux" ]]; then
        echo "❌ コミットは NixOS/WSL からのみ許可されています"
        return 1
    fi
    if [[ -f /etc/os-release ]] && grep -q "NixOS" /etc/os-release 2>/dev/null; then
        echo "✓ NixOS 環境を確認"
    else
        echo "✓ Linux 環境を確認"
    fi
    return 0
}

run_formatter() {
    if command -v nix &>/dev/null; then
        echo "Running nix fmt..."
        if ! nix fmt 2>/dev/null; then
            echo "❌ フォーマットエラー"
            return 1
        fi
        git add -u
        echo "✓ フォーマット完了"
    fi
    return 0
}

main() {
    echo "=== Pre-commit checks ==="
    check_environment || exit 1
    run_formatter || exit 1
    echo "=== All checks passed ==="
}

main "$@"
