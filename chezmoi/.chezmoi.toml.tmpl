# chezmoi configuration

sourceDir = {{ .chezmoi.sourceDir | quote }}

[interpreters.ps1]
    command = "powershell"
    args = ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File"]

[data.git]
    name = {{ promptStringOnce . "git.name" "Git user name" | quote }}
    email = {{ promptStringOnce . "git.email" "Git email address" | quote }}
    signingkey = {{ promptStringOnce . "git.signingkey" "SSH signing key path (default: ~/.ssh/signing_key.pub)" | default "~/.ssh/signing_key.pub" | quote }}
