{
  "agents": {
    "defaults": {
      "workspace": "/app/data/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "{{ onepasswordRead "op://Personal/TelegramBot/password" }}",
      "dmPolicy": "allowlist",
      "allowFrom": ["tg:{{ onepasswordRead "op://Personal/TelegramBot/username" }}"],
      "streaming": "block"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "{{ onepasswordRead "op://Personal/openclaw/gateway token" }}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    }
  }
}
