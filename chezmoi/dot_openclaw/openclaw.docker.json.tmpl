{
  "agents": {
    "defaults": {
      "workspace": "/app/data/workspace",
      "model": "openai-codex/gpt-5.3-codex",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5
      },
      "sandbox": {
        "sessionToolsVisibility": "all"
      }
    }
  },
  "tools": {
    "sessions": {
      "visibility": "tree"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "{{ onepasswordRead "op://Personal/TelegramBot/credential" }}",
      "dmPolicy": "allowlist",
      "allowFrom": ["{{ .telegramUserId }}"],
      "streaming": "block"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "{{ onepasswordRead "op://Personal/openclaw/gateway token" }}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "acpx",
      "google-gemini-cli-auth"
    ],
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "/usr/local/bin/acpx"
        }
      },
      "google-gemini-cli-auth": {
        "enabled": true
      }
    }
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "dispatch": {
      "enabled": true
    }
  }
}
