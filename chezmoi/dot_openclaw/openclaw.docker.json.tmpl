{
  "agents": {
    "defaults": {
      "workspace": "{{ .openclaw.workspace.sandboxPath }}",
      "model": {
        "primary": "{{ .openclaw.models.primary }}",
        "fallbacks": ["{{ .openclaw.models.fallback }}"]
      },
      "models": {
        "{{ .openclaw.models.primary }}": { "alias": "gpt54" },
        "{{ .openclaw.models.fallback }}": { "alias": "codex" },
        "anthropic/claude-sonnet-4-6": { "alias": "sonnet" }
      },
      "imageModel": {
        "primary": "{{ .openclaw.models.image }}"
      },
      "pdfModel": {
        "primary": "{{ .openclaw.models.pdf }}"
      },
      "thinkingDefault": "{{ .openclaw.agent.thinkingDefault }}",
      "timeoutSeconds": {{ .openclaw.agent.timeoutSeconds }},
      "contextTokens": {{ .openclaw.agent.contextTokens }},
      "maxConcurrent": {{ .openclaw.agent.maxConcurrent }},
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": {{ .openclaw.compaction.reserveTokensFloor }},
        "identifierPolicy": "strict",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": {{ .openclaw.compaction.memoryFlushSoftThreshold }}
        }
      },
      "memorySearch": {
        "enabled": true,
        "sources": ["memory", "sessions"],
        "experimental": {
          "sessionMemory": true
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "{{ .openclaw.contextPruning.ttl }}",
        "keepLastAssistants": {{ .openclaw.contextPruning.keepLastAssistants }},
        "softTrimRatio": {{ .openclaw.contextPruning.softTrimRatio }},
        "hardClearRatio": {{ .openclaw.contextPruning.hardClearRatio }},
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Old tool result content cleared]"
        }
      },
      "subagents": {
        "model": "{{ .openclaw.models.subagent }}",
        "maxConcurrent": {{ .openclaw.subagent.maxConcurrent }},
        "maxSpawnDepth": {{ .openclaw.subagent.maxSpawnDepth }},
        "maxChildrenPerAgent": {{ .openclaw.subagent.maxChildrenPerAgent }},
        "runTimeoutSeconds": {{ .openclaw.subagent.runTimeoutSeconds }},
        "archiveAfterMinutes": {{ .openclaw.subagent.archiveAfterMinutes }}
      },
      "sandbox": {
        "sessionToolsVisibility": "all",
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox-common:bookworm-slim",
          "network": "bridge",
          "user": "1000:1000",
          "readOnlyRoot": false,
          "tmpfs": ["/tmp", "/var/tmp", "/run"],
          "capDrop": ["ALL"],
          "pidsLimit": {{ .openclaw.sandbox.pidsLimit }},
          "memory": "{{ .openclaw.sandbox.memory }}",
          "memorySwap": "{{ .openclaw.sandbox.memorySwap }}",
          "cpus": {{ .openclaw.sandbox.cpus }},
          "env": {
            "GITHUB_TOKEN": "@@GITHUB_TOKEN@@",
            "GH_TOKEN": "@@GITHUB_TOKEN@@",
            "XAI_API_KEY": "@@XAI_API_KEY@@",
            "PLAYWRIGHT_BROWSERS_PATH": "/home/node/.cache/ms-playwright",
            "GIT_CONFIG_COUNT": "1",
            "GIT_CONFIG_KEY_0": "url.https://x-access-token:@@GITHUB_TOKEN@@@github.com/.insteadOf",
            "GIT_CONFIG_VALUE_0": "https://github.com/"
          }
        },
        "prune": {
          "idleHours": {{ .openclaw.prune.idleHours }}
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      },
      {
        "id": "claude",
        "model": "{{ .openclaw.agentModels.claude.primary }}",
        "workspace": "/home/app/.openclaw/workspace-claude",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "claude",
            "backend": "acpx"
          }
        }
      },
      {
        "id": "gemini",
        "model": "{{ .openclaw.agentModels.gemini.primary }}",
        "workspace": "/home/app/.openclaw/workspace-gemini",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "gemini",
            "backend": "acpx"
          }
        }
      },
{{- /* --- Slack per-channel agents (ACP 経由 Claude Code) ---
     「1エージェント = 1チャンネル」設計。各チャンネルに専用エージェントを割り当て、
     コンテキスト混入を防止する。ACP 経由が必須（Claude Max の直接モデル指定は ToS 違反）。
     チャンネルリストは .chezmoidata/openclaw.yaml の slackAgents で一元管理。
     binding にマッチしない Slack DM / Telegram は main にフォールバック。 */ -}}
{{- $lastSlack := sub (len .openclaw.slackAgents) 1 -}}
{{- range $i, $agent := .openclaw.slackAgents }}
      {
        "id": "{{ $agent.id }}",
        "model": "{{ $.openclaw.agentModels.claude.primary }}",
        "workspace": "/home/app/.openclaw/workspace-{{ $agent.id }}",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "claude",
            "backend": "acpx"
          }
        }
      }{{ if lt $i $lastSlack }},{{ end }}
{{- end }}
    ]
  },
  {{- /* --- Bindings: Slack チャンネル → 専用エージェントへのルーティング ---
       peer.kind="channel" でチャンネル ID ベースのマッチング。
       most-specific-wins ルールにより、ここで定義されたチャンネルは専用エージェントに、
       それ以外は default (main) エージェントにルーティングされる。 */ -}}
  "bindings": [
{{- $lastBind := sub (len .openclaw.slackAgents) 1 -}}
{{- range $i, $agent := .openclaw.slackAgents }}
    {
      "agentId": "{{ $agent.id }}",
      "match": { "channel": "slack", "peer": { "kind": "channel", "id": "{{ $agent.channelId }}" } }
    }{{ if lt $i $lastBind }},{{ end }}
{{- end }}
  ],
  "tools": {
    "profile": "coding",
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    },
    "exec": {
      "timeoutSec": {{ .openclaw.tools.execTimeoutSec }},
      "backgroundMs": {{ .openclaw.tools.execBackgroundMs }},
      "cleanupMs": {{ .openclaw.tools.execCleanupMs }},
      "notifyOnExit": true,
      "notifyOnExitEmptySuccess": false
    },
    "web": {
      "search": {
        "enabled": true,
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "maxChars": {{ .openclaw.tools.webFetchMaxChars }},
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      }
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
{{- if lookPath "op" }}
      "botToken": "{{ onepasswordRead "op://Personal/TelegramBot/credential" }}",
{{- else }}
      "botToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
{{- end }}
      "dmPolicy": "allowlist",
{{- if lookPath "op" }}
      "allowFrom": ["{{ onepasswordRead "op://Personal/TelegramBot/user_id" }}"],
{{- else }}
      "allowFrom": ["PLACEHOLDER_REQUIRES_OP_SIGNIN"],
{{- end }}
      "streaming": "block",
      "historyLimit": {{ .openclaw.channels.telegramHistoryLimit }},
      "replyToMode": "first",
      "retry": {
        "attempts": 5,
        "minDelayMs": 1000,
        "maxDelayMs": 30000,
        "jitter": 0.3
      },
      "network": {
        "autoSelectFamily": false,
        "dnsResultOrder": "ipv4first"
      }
    },
    "slack": {
      "enabled": true,
      "mode": "socket",
{{- if lookPath "op" }}
      "botToken": "{{ onepasswordRead "op://Personal/SlackBot-OpenClaw/bot_token" }}",
      "appToken": "{{ onepasswordRead "op://Personal/SlackBot-OpenClaw/app_level_token" }}",
      "dmPolicy": "allowlist",
      "allowFrom": ["{{ onepasswordRead "op://Personal/22w7ub2pldlpo6tlmggc7g67mu/Miki _Co/slack_user_id" }}"],
{{- else }}
      "botToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
      "appToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
      "dmPolicy": "allowlist",
      "allowFrom": ["PLACEHOLDER_REQUIRES_OP_SIGNIN"],
{{- end }}
      "groupPolicy": "allowlist",
      {{- /* slackAgents から許可チャンネル一覧を自動生成 */ -}}
      "channels": {
{{- $lastCh := sub (len .openclaw.slackAgents) 1 -}}
{{- range $i, $agent := .openclaw.slackAgents }}
        "{{ $agent.channelId }}": {"requireMention": true}{{ if lt $i $lastCh }},{{ end }}
{{- end }}
      },
      "streaming": "partial",
      "historyLimit": {{ .openclaw.channels.slackHistoryLimit }},
      "replyToMode": "off",
      "thread": {
        "historyScope": "thread",
        "inheritParent": false
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "queue": {
      "mode": "collect",
      "debounceMs": {{ .openclaw.messages.queueDebounceMs }},
      "cap": 20,
      "drop": "summarize"
    },
    "inbound": {
      "debounceMs": {{ .openclaw.messages.inboundDebounceMs }}
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "idle",
      "idleMinutes": {{ .openclaw.session.idleMinutes }}
    },
    "resetTriggers": ["/new", "/reset"],
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "{{ .openclaw.session.pruneAfter }}",
      "maxEntries": {{ .openclaw.session.maxEntries }}
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "reload": {
      "mode": "hybrid"
    },
    "auth": {
      "mode": "token",
{{- if lookPath "op" }}
      "token": "{{ onepasswordRead "op://Personal/openclaw/gateway token" }}"
{{- else }}
      "token": "PLACEHOLDER_REQUIRES_OP_SIGNIN"
{{- end }}
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "pnpm"
    },
    "load": {
      "extraDirs": ["/app/data/superpowers/skills"]
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "slack",
      "acpx",
      "google-gemini-cli-auth",
      "openclaw-mcp-bridge"
    ],
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "/usr/local/bin/acpx"
        }
      },
      "google-gemini-cli-auth": {
        "enabled": true
      },
      "openclaw-mcp-bridge": {
        "enabled": true,
        "config": {
          "mode": "direct",
          "toolPrefix": true,
          "servers": {
            "cognee-skills": {
              "transport": "streamable-http",
              "url": "http://cognee-mcp-skills:8000/mcp",
              "description": "Cognee MCP skills"
            }
          }
        }
      }
    }
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "dispatch": {
      "enabled": true
    }
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "searchMode": "search",
      "includeDefaultMemory": true
    }
  }
}
