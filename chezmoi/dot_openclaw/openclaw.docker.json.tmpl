{
  "agents": {
    "defaults": {
      "workspace": "/app/data",
      "model": "openai-codex/gpt-5.3-codex",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5
      },
      "sandbox": {
        "sessionToolsVisibility": "all",
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox-common:bookworm-slim",
          "network": "none",
          "user": "0:0"
        }
      }
    }
  },
  "tools": {
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
{{- if lookPath "op" }}
      "botToken": "{{ onepasswordRead "op://Personal/TelegramBot/credential" }}",
{{- else }}
      "botToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
{{- end }}
      "dmPolicy": "allowlist",
{{- if lookPath "op" }}
      "allowFrom": ["{{ onepasswordRead "op://Personal/TelegramBot/user_id" }}"],
{{- else }}
      "allowFrom": ["PLACEHOLDER_REQUIRES_OP_SIGNIN"],
{{- end }}
      "streaming": "block"
    },
    "slack": {
      "enabled": true,
      "mode": "socket",
{{- if lookPath "op" }}
      "botToken": "{{ onepasswordRead "op://Personal/SlackBot-OpenClaw/bot_token" }}",
      "appToken": "{{ onepasswordRead "op://Personal/SlackBot-OpenClaw/app_level_token" }}",
      "dmPolicy": "allowlist",
      "allowFrom": ["{{ onepasswordRead "op://Personal/22w7ub2pldlpo6tlmggc7g67mu/Miki _Co/slack_user_id" }}"],
{{- else }}
      "botToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
      "appToken": "PLACEHOLDER_REQUIRES_OP_SIGNIN",
      "dmPolicy": "allowlist",
      "allowFrom": ["PLACEHOLDER_REQUIRES_OP_SIGNIN"],
{{- end }}
      "groupPolicy": "allowlist",
      "channels": {
        "C0AK3SQKFV2": {"requireMention": true},
        "C0AK64UPVNW": {"requireMention": true},
        "C0AJVDKGN6A": {"requireMention": true},
        "C0AJZSPV84S": {"requireMention": true}
      },
      "streaming": "block"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
{{- if lookPath "op" }}
      "token": "{{ onepasswordRead "op://Personal/openclaw/gateway token" }}"
{{- else }}
      "token": "PLACEHOLDER_REQUIRES_OP_SIGNIN"
{{- end }}
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "bun"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "slack",
      "acpx",
      "google-gemini-cli-auth"
    ],
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "command": "/usr/local/bin/acpx"
        }
      },
      "google-gemini-cli-auth": {
        "enabled": true
      }
    }
  },
  "acp": {
    "enabled": true,
    "backend": "acpx",
    "dispatch": {
      "enabled": true
    }
  }
}

