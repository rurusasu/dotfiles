{{- $telegramUserId := "PLACEHOLDER_REQUIRES_OP_SIGNIN" -}}
{{- if lookPath "op" -}}
{{-   $telegramUserId = onepasswordRead "op://Personal/TelegramBot/user_id" -}}
{{- end -}}
{{- $ws := .openclaw.workspace.sandboxPath -}}
{
  "version": 1,
  "jobs": [
    {
      "id": "16d4e720-d83a-4ea2-aa94-9bfe912ab1a9",
      "agentId": "main",
      "sessionKey": "agent:main:telegram:direct:{{ $telegramUserId }}",
      "name": "lifelog-daily-scaffold",
      "enabled": true,
      "createdAtMs": 1772578800776,
      "updatedAtMs": 1772578837691,
      "schedule": {
        "kind": "cron",
        "expr": "55 23 * * *",
        "tz": "Asia/Tokyo"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Run in {{ $ws }}/lifelog: `bun run new`.\n\nThen send exactly one short status message:\n- Success: \"✅ lifelog scaffold created/checked for today (daily/weekly/monthly/yearly).\"\n- Failure: \"⚠️ lifelog scaffold failed: <brief reason>\""
      },
      "delivery": {
        "mode": "announce"
      }
    },
    {
      "id": "acc4b111-8ed1-4f5a-bc75-9330e2aeedcc",
      "agentId": "main",
      "sessionKey": "agent:main:telegram:direct:{{ $telegramUserId }}",
      "name": "lifelog-daily-git-sync",
      "enabled": true,
      "createdAtMs": 1772578883782,
      "updatedAtMs": 1772578883782,
      "schedule": {
        "kind": "cron",
        "expr": "58 23 * * *",
        "tz": "Asia/Tokyo"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "In {{ $ws }}/lifelog, run:\n1) `git add daily weekly monthly yearly`\n2) If there are no staged changes, send: \"ℹ️ lifelog sync: no changes to commit today.\"\n3) If there are changes, commit with message: `chore(lifelog): daily scaffold update for $(date +%F)` and push to `origin main`, then send: \"✅ lifelog sync pushed to GitHub.\"\n4) On any failure, send: \"⚠️ lifelog sync failed: <brief reason>\""
      },
      "delivery": {
        "mode": "announce",
        "to": "{{ $telegramUserId }}",
        "channel": "telegram"
      }
    },
    {
      "id": "c542f9b7-6eba-49b5-bb50-cf83857386c1",
      "agentId": "main",
      "name": "workspace-git-sync",
      "enabled": true,
      "createdAtMs": 1773936163895,
      "updatedAtMs": 1773936163895,
      "schedule": {
        "kind": "every",
        "everyMs": 600000,
        "anchorMs": 1773936163895
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "In {{ $ws }}, run:\n1) `git add -A`\n2) If there are no staged changes: do nothing silently.\n3) If there are staged changes: commit with message `chore(workspace): auto-sync $(date +%F_%H%M)` and push to `origin main`.\n4) Then `git pull --ff-only origin main` to pick up any remote changes.\n5) On any failure, report briefly."
      },
      "delivery": {
        "mode": "silent"
      }
    },
    {
      "id": "f1a2b3c4-sandbox-gc-0001-000000000001",
      "agentId": "main",
      "sessionKey": "agent:main:telegram:direct:{{ $telegramUserId }}",
      "name": "sandbox-gc",
      "enabled": true,
      "createdAtMs": 1741510800000,
      "updatedAtMs": 1741510800000,
      "schedule": {
        "kind": "cron",
        "expr": "0 * * * *",
        "tz": "Asia/Tokyo"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Run sandbox garbage collection: remove all exited sandbox containers.\n\nExecute: `docker ps -aq --filter ancestor=openclaw-sandbox-common:bookworm-slim --filter status=exited | xargs -r docker rm`\n\nDo NOT send a message unless containers were actually removed. If removed, send: \"🧹 sandbox-gc: removed N exited container(s).\""
      },
      "delivery": {
        "mode": "silent"
      }
    }
  ]
}
