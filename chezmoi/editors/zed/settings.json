{
  // Zed settings - uses JSONC format (comments allowed)
  // Extensions - auto-install listed extensions, unlisted ones are removed
  "auto_install_extensions": {
    "github-theme": true,
    "powershell": true,
    "dprint": true,
    "nix": true,
    "toml": true,
    "lua": true,
    "oxc": true,
    "ruff": true,
    "python-refactoring": true,
    "material-icon-theme": true,
    "typos": true,
    "github-actions": true,
    "comments-highlighter": true,
    "dockerfile": true,
    "docker-compose": false,
    "mcp-server-github": false,
    "mcp-server-linear": false
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "theme": "GitHub Dark Dimmed",
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "buffer_font_family": "Consolas",
  // Vim mode
  "vim_mode": false,
  // Editor settings
  "format_on_save": "on",
  "formatter": "language_server",
  "show_whitespaces": "all",
  "cursor_blink": true,
  "relative_line_numbers": true,
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 8,
  "scrollbar": {
    "show": "auto"
  },
  "seed_search_query_from_cursor": "always",
  "gutter": {
    "line_numbers": true,
    "code_actions": true,
    "folds": true
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },
  "inlay_hints": {
    "enabled": true
  },
  "soft_wrap": "editor_width",
  // Tab display stabilization (Zed has no fixed tab width setting)
  "max_tabs": 20,
  "tabs": {
    "show_close_button": "always"
  },
  // Terminal settings
  "terminal": {
    "shell": {
      "program": "pwsh"
    },
    "font_size": 13,
    "line_height": "comfortable",
    "copy_on_select": false,
    "vim_mode": false
  },
  // File settings
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/node_modules",
    "**/target",
    "**/build",
    "**/dist",
    "**/.DS_Store"
  ],
  // Git settings
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  // Project panel
  "project_panel": {
    "dock": "left",
    "auto_reveal_entries": true,
    "auto_fold_dirs": true
  },
  // Language-specific settings
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "file.js"]
        }
      }
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "file.ts"]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "file.json"]
        }
      }
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "file.yaml"]
        }
      }
    },
    "TOML": {
      "formatter": {
        "external": {
          "command": "taplo",
          "arguments": ["format", "-"]
        }
      }
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "dprint",
          "arguments": ["fmt", "--stdin", "md"]
        }
      },
      "soft_wrap": "editor_width"
    },
    "Lua": {
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["-"]
        }
      }
    },
    "PowerShell": {
      "formatter": "language_server"
    },
    "Nix": {
      "language_servers": ["nixd"],
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": []
        }
      }
    },
    "Shell Script": {
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-"]
        }
      }
    },
    "Python": {
      "format_on_save": "on",
      "formatter": "language_server",
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyright"],
      "soft_wrap": "bounded",
      "preferred_line_length": 88
    },
    "Dockerfile": {
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "Jupyter": {
      "format_on_save": "on",
      "formatter": "language_server",
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyright"]
    }
  },
  // LSP settings
  "lsp": {
    "nixd": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"]
        },
        "options": {
          "nixos": {
            "expr": "(builtins.getFlake \"/home/vscode/.dotfiles\").nixosConfigurations.nixos.options"
          }
        }
      }
    },
    "ty": {
      "initialization_options": {
        "settings": {
          "diagnosticMode": "openFilesOnly",
          "inlayHints": {
            "variableTypes": true,
            "callArgumentNames": true,
            "genericTypes": true
          }
        }
      }
    },
    "typos": {
      "initialization_options": {
        "config": "_typos.toml",
        "diagnosticSeverity": "Information"
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 88,
          "lint": {
            "preview": true
          },
          "format": {
            "preview": true
          },
          "organizeImports": true,
          "fixAll": true,
          "codeAction": {
            "fixViolation": {
              "enable": true
            },
            "disableRuleComment": {
              "enable": true
            }
          }
        }
      }
    }
  },
  // Agent (AI) settings
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    }
  },
  // External agents via ACP (Agent Client Protocol).
  //
  // Each registry-typed adapter is auto-installed by Zed on first use and
  // spawns the corresponding native CLI, which reads its own config files
  // (~/.claude.json, ~/.codex/config.toml, ~/.gemini/settings.json, etc.).
  // That means MCP servers and other settings declared in the chezmoi
  // mcp_servers.yaml chain (and per-CLI native configs) flow through to
  // Zed's Agent Panel automatically — no duplicate wiring here.
  //
  // Notes:
  // - claude-acp / codex-acp support MCP servers; the gemini adapter does
  //   not currently expose MCP (per Zed docs).
  // - opencode is in Zed's ACP registry directly (no -acp suffix).
  // - Cursor is not in Zed's registry; we bridge cursor-agent through the
  //   community npm adapter `cursor-acp`. Requires the cursor-agent CLI.
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "Cursor": {
      "type": "custom",
      "command": "pnpm",
      "args": ["dlx", "cursor-acp"]
    }
  }
}
