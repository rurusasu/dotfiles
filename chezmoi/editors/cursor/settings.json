{
  "editor.fontSize": 12,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ibecker.treefmt-vscode",
  "editor.minimap.enabled": true,
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 80,
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "line",
  "editor.renderWhitespace": "all",
  "editor.smoothScrolling": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeLens": true,
  "editor.wordBasedSuggestions": "allDocuments",
  "editor.tabCompletion": "on",
  "editor.quickSuggestionsDelay": 200,
  "editor.suggestSelection": "recentlyUsed",
  "editor.linkedEditing": true,
  "editor.parameterHints.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineHints.enabled": "on",
  "editor.formatOnType": true,
  "editor.stickyTabStops": true,
  "editor.selectionHighlight": true,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.guides.indentation": true,
  "editor.folding": true,
  "editor.unicodeHighlight.allowedLocales": {
    "ja": true
  },
  "editor.unicodeHighlight.nonBasicASCII": true,
  "editor.unicodeHighlight.ambiguousCharacters": true,
  "editor.stickyScroll.enabled": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.lightbulb.enabled": "on",
  "editor.hover.enabled": true,
  "editor.scrollBeyondLastLine": true,
  "editor.occurrencesHighlight": "singleFile",
  "editor.renderControlCharacters": true,
  "editor.suggest.showSnippets": false,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.showIcons": true,
  "editor.minimap.renderCharacters": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.suggest.localityBonus": false,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggest.insertMode": "replace",
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggest.selectionMode": "always",
  "editor.snippetSuggestions": "top",
  "editor.suggestFontSize": 12,
  "editor.suggest.preview": true,
  "editor.suggest.showInlineDetails": true,
  "editor.mouseWheelZoom": true,
  "editor.multiCursorModifier": "alt",
  "editor.formatOnPaste": false,
  "editor.formatOnSaveMode": "modifications",
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.autoClosingBrackets": "languageDefined",
  "editor.autoClosingQuotes": "languageDefined",
  "editor.autoSurround": "languageDefined",
  "editor.gotoLocation.multipleDefinitions": "gotoAndPeek",
  "editor.gotoLocation.multipleDeclarations": "gotoAndPeek",
  "editor.gotoLocation.multipleTypeDefinitions": "gotoAndPeek",
  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "newUntitledFile",
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "last",
  "workbench.editor.enablePreview": false,
  "workbench.sideBar.location": "left",
  "workbench.activityBar.location": "left",
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabSizing": "fixed",
  "workbench.editor.tabSizingFixedMinWidth": 180,
  "workbench.editor.tabSizingFixedMaxWidth": 180,
  "workbench.commandPalette.preserveInput": true,
  "workbench.activityBar.visible": true,
  "workbench.activityBar.orientation": "vertical",
  "workbench.enableExperiments": true,
  "workbench.statusBar.visible": true,
  "workbench.list.smoothScrolling": true,
  "workbench.layoutControl.enabled": true,
  "workbench.commandPalette.history": 50,
  "window.openFoldersInNewWindow": "off",
  "window.zoomLevel": 0,
  "window.newWindowDimensions": "default",
  "window.restoreWindows": "all",
  "files.watcherExclude": {
    "**/target/**": true,
    "**/build/**": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true
  },
  "files.autoSave": "onFocusChange",
  "files.simpleDialog.enable": false,
  "files.restoreUndoStack": true,
  "files.defaultLanguage": "markdown",
  "terminal.integrated.defaultLocation": "view",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.DS_Store": true
  },
  "explorer.confirmDelete": true,
  "explorer.compactFolders": true,
  "explorer.confirmDragAndDrop": true,
  "search.followSymlinks": true,
  "search.useIgnoreFiles": true,
  "search.exclude": {
    "**/node_modules/**": true,
    "**/bower_components/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/coverage/**": true
  },
  "search.smartCase": true,
  "notebook.cellToolbarLocation": {
    "default": "left"
  },
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.allowChords": false,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.terminal.toggleTerminal",
    "workbench.action.focusActiveEditorGroup",
    "workbench.action.focusNextGroup",
    "workbench.action.focusPreviousGroup",
    "workbench.action.quickOpen"
  ],
  "terminal.integrated.rightClickBehavior": "copyPaste",
  "terminal.integrated.splitCwd": "workspaceRoot",
  "terminal.integrated.scrollback": 1000,
  "diffEditor.renderSideBySide": true,
  "accessibility.signals.terminalBell": {
    "sound": "off"
  },
  "debug.openDebug": "openOnFirstSessionStart",
  "security.workspace.trust.enabled": true,
  "debug.console.wordWrap": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": false,
  "git.openRepositoryInParentFolders": "always",
  "git.pruneOnFetch": true,
  "git.mergeEditor": true,
  "git.pullTags": true,
  "scm.alwaysShowRepositories": true,
  "problems.autoReveal": false,
  "scm.diffDecorations": "all",
  "telemetry.telemetryLevel": "off",
  "task.problemMatchers.neverPrompt": true,
  "extensions.autoUpdate": true,
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "dprint.dprint",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.formatOnSave": true
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["nixfmt"]
      },
      "options": {
        "nixos": {
          "expr": "(builtins.getFlake \"/home/vscode/.dotfiles\").nixosConfigurations.nixos.options"
        }
      }
    }
  },
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.formatOnSave": true
  },
  "[notebook]": {
    "notebook.formatOnSave.enabled": true,
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "notebook.codeActionsOnSave": {
      "notebook.source.fixAll": "explicit",
      "notebook.source.organizeImports": "explicit"
    }
  },
  "jupyter.askForKernelRestart": false,
  "jupyter.enablePlotViewer": true,
  "jupyter.themeMatplotlibPlots": true,
  "jupyter.widgetScriptSources": ["jsdelivr.com", "unpkg.com"],
  "jupyter.exportWithOutputEnabled": true,
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "[python]": {
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit",
      "source.organizeImports": "explicit",
      "source.removeUnusedImports": "explicit"
    },
    "editor.detectIndentation": true,
    "editor.rulers": [88],
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 88,
    "editor.suggestSelection": "first"
  },
  "ruff.nativeServer": "on",
  "ruff.enable": true,
  "ruff.path": ["${workspaceFolder}/.venv/bin/ruff"],
  "ruff.configuration": "${workspaceFolder}/pyproject.toml",
  "ruff.lint.run": "onSave",
  "ruff.lint.preview": true,
  "ruff.organizeImports": true,
  "ruff.fixAll": true,
  "ruff.format.preview": true,
  "ruff.showNotifications": "onError",
  "ruff.codeAction.fixViolation.enable": true,
  "ruff.codeAction.disableRuleComment.enable": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [],
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python-envs.pythonProjects": [],
  "python.languageServer": "None",
  "ty.enable": true,
  "ty.configuration": "${workspaceFolder}/pyproject.toml",
  "ty.disableLanguageServices": false,
  "ty.completions.autoImport": true,
  "ty.logLevel": "info",
  "powershell.scriptAnalysis.enable": true,
  "powershell.scriptAnalysis.settingsPath": "PSScriptAnalyzerSettings.psd1",
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.trimWhitespaceAroundPipe": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": true,
  "powershell.integratedConsole.showOnStartup": false,
  "task.outputTo": "terminal",
  "task.tree.nesting": true,
  "task.tree.sort": "alphanumeric",
  "task.checkForUpdates": false,
  "task.notifyWindowOnTaskCompletion": 0,
  "typos.config": "${workspaceFolder}/_typos.toml",
  "editor.lineNumbers": "on",
  "editor.cursorSurroundingLines": 8,
  "workbench.list.automaticKeyboardNavigation": false,
  "editor.find.seedSearchStringFromSelection": "always",
  "cursor.cpp.disabledLanguages": [],
  "cursor.general.enableShadowWorkspace": true
}
