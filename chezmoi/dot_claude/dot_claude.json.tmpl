{
  "mcpServers": {
{{- $first := true }}
{{- if hasKey . "mcp_servers" }}
{{- range .mcp_servers }}
{{- if has "claude" .supports }}
{{- if not $first }},{{ end }}
{{- $first = false }}
    "{{ .name }}": {
{{- if and (hasKey . "url") (not (hasKey . "command")) }}
      "url": "{{ .url }}"
{{- else }}
      "command": "{{ .command }}",
      "args": [{{ range $i, $arg := .args }}{{ if $i }}, {{ end }}"{{ $arg }}"{{ end }}]
{{- end }}
{{- if hasKey . "env" }},
      "env": {
{{- $envFirst := true }}
{{- range $key, $value := .env }}
{{- if not $envFirst }},{{ end }}
{{- $envFirst = false }}
        "{{ $key }}": "{{ $value }}"
{{- end }}
      }
{{- end }}
    }
{{- end }}
{{- end }}
{{- end }}
  }
}
