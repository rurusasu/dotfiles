{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
# Deploy Kaggle API credentials for Linux/macOS
{{- $opCmd := or (lookPath "op") (lookPath "op.exe") }}
{{- $opPersonal := false }}
{{- $opAccounts := "" }}
{{- if $opCmd }}{{ $opAccounts = output "sh" "-c" (printf "'%s' account list 2>/dev/null || true" $opCmd) }}{{ end }}
{{- $opPersonal = contains .op_account_personal $opAccounts }}
{{- if $opPersonal }}
# token-hash: {{ onepasswordRead "op://Private/Kaggle/c4patuuzwob2vcwt43qqphoyeu" .op_account_personal | sha256sum }}
{{- end }}

set -euo pipefail

HOME_DIR="${HOME:-/home/$(whoami)}"
KAGGLE_DIR="$HOME_DIR/.kaggle"

{{- if $opPersonal }}
echo "Deploying Kaggle API credentials..."

mkdir -p "$KAGGLE_DIR"

TOKEN='{{ onepasswordRead "op://Private/Kaggle/c4patuuzwob2vcwt43qqphoyeu" .op_account_personal }}'

# New API Token method: ~/.kaggle/access_token
printf '%s' "$TOKEN" > "$KAGGLE_DIR/access_token"
chmod 600 "$KAGGLE_DIR/access_token"

echo "Deployed: $KAGGLE_DIR/access_token"
{{- else }}
echo "WARNING: 1Password personal account not signed in, skipping Kaggle API credentials deployment"
{{- end }}
{{ end -}}
