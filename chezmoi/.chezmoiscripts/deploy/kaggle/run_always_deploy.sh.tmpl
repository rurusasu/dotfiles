{{ if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Deploy Kaggle API credentials for Linux/macOS
set -euo pipefail

OP_ACCOUNT="{{ .op_account_personal }}"
SECRET_REF="op://Private/Kaggle/c4patuuzwob2vcwt43qqphoyeu"
OP_READ_TIMEOUT_SECONDS=60

OP_CACHE_ARGS=()
if [ -n "${WSL_DISTRO_NAME:-}" ] && command -v op.exe >/dev/null 2>&1; then
  OP_CMD="$(command -v op.exe)"
  OP_CACHE_ARGS=(--cache=false)
elif command -v op >/dev/null 2>&1; then
  OP_CMD="$(command -v op)"
elif command -v op.exe >/dev/null 2>&1; then
  OP_CMD="$(command -v op.exe)"
  OP_CACHE_ARGS=(--cache=false)
else
  echo "WARNING: 1Password CLI not found, skipping Kaggle API credentials deployment"
  exit 0
fi

if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD="$(command -v timeout)"
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD="$(command -v gtimeout)"
else
  echo "WARNING: timeout command not found, skipping Kaggle API credentials deployment"
  exit 0
fi

echo "Deploying Kaggle API credentials..."

ERR_FILE="$(mktemp)"
trap 'rm -f "$ERR_FILE"' EXIT

if TOKEN="$("$TIMEOUT_CMD" "${OP_READ_TIMEOUT_SECONDS}s" "$OP_CMD" "${OP_CACHE_ARGS[@]}" read "$SECRET_REF" --account "$OP_ACCOUNT" 2>"$ERR_FILE")"; then
  EXIT_CODE=0
else
  EXIT_CODE=$?
fi
if [ "$EXIT_CODE" -ne 0 ]; then
  if [ "$EXIT_CODE" -eq 124 ]; then
    echo "WARNING: 1Password read timed out after $OP_READ_TIMEOUT_SECONDS seconds, skipping Kaggle API credentials deployment"
  else
    echo "WARNING: 1Password is not available, skipping Kaggle API credentials deployment"
  fi
  sed 's/^/  /' "$ERR_FILE" || true
  exit 0
fi

if [ -z "$TOKEN" ]; then
  echo "WARNING: Kaggle API credential is empty, skipping deployment"
  exit 0
fi

HOME_DIR="${HOME:-/home/$(whoami)}"
KAGGLE_DIR="$HOME_DIR/.kaggle"

mkdir -p "$KAGGLE_DIR"

# New API Token method: ~/.kaggle/access_token
printf '%s' "$TOKEN" > "$KAGGLE_DIR/access_token"
chmod 600 "$KAGGLE_DIR/access_token"

echo "Deployed: $KAGGLE_DIR/access_token"
{{ end -}}
