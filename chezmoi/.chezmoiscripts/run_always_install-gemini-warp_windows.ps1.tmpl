{{ if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

# gemini CLI が利用可能か確認
$geminiCmd = Get-Command gemini -ErrorAction SilentlyContinue
if (-not $geminiCmd) {
  Write-Host "[gemini-warp] Skip: gemini CLI not found."
  return
}

$timeoutSeconds = 120
if ($env:DOTFILES_GEMINI_WARP_TIMEOUT_SECONDS) {
  $parsedTimeout = 0
  if ([int]::TryParse($env:DOTFILES_GEMINI_WARP_TIMEOUT_SECONDS, [ref]$parsedTimeout) -and $parsedTimeout -gt 0) {
    $timeoutSeconds = $parsedTimeout
  }
}

$extensionUrl = "https://github.com/warpdotdev/gemini-cli-warp"
$geminiArgs = @("extensions", "install", $extensionUrl, "--consent")
$script:geminiExitCode = $null

function Write-GeminiWarpOutput {
  param([object[]]$Lines)

  foreach ($line in @($Lines)) {
    $text = [string]$line
    if ($text -match "^__DOTFILES_GEMINI_EXIT_CODE=(\d+)$") {
      $script:geminiExitCode = [int]$Matches[1]
      continue
    }
    if (-not [string]::IsNullOrWhiteSpace($text)) {
      Write-Host $text
    }
  }
}

Write-Host "[gemini-warp] Installing Warp extension..."
Write-Host "[gemini-warp] Command: gemini $($geminiArgs -join ' ')"

$job = Start-Job -ScriptBlock {
  param([string]$GeminiPath, [string[]]$Arguments)

  & $GeminiPath @Arguments 2>&1 | ForEach-Object { $_ }
  "__DOTFILES_GEMINI_EXIT_CODE=$LASTEXITCODE"
} -ArgumentList $geminiCmd.Source, $geminiArgs

try {
  $deadline = (Get-Date).AddSeconds($timeoutSeconds)
  while ($job.State -eq "Running") {
    Write-GeminiWarpOutput -Lines (Receive-Job -Job $job)
    if ((Get-Date) -gt $deadline) {
      Stop-Job -Job $job -ErrorAction SilentlyContinue
      Write-Host "[gemini-warp] Warning: extension install timed out after $timeoutSeconds seconds."
      Write-Host "[gemini-warp] The command may be waiting for an interactive Gemini trust prompt."
      return
    }
    Start-Sleep -Seconds 1
  }

  Write-GeminiWarpOutput -Lines (Receive-Job -Job $job)
}
finally {
  Remove-Job -Job $job -Force -ErrorAction SilentlyContinue
}

if ($null -eq $script:geminiExitCode) {
  $script:geminiExitCode = 1
}

if ($script:geminiExitCode -ne 0) {
  Write-Host "[gemini-warp] Warning: extension install returned non-zero (may already be installed)"
}
Write-Host "[gemini-warp] Done. Restart Gemini CLI for the extension to activate."
{{ end -}}
