{
  "mcpServers": {
{{- $first := true }}
{{- $opCmd := or (lookPath "op") (lookPath "op.exe") }}
{{- $opReadFailed := false }}
{{- $opReadTimeoutSeconds := 5 }}
{{- if hasKey . "mcp_servers" }}
{{- range .mcp_servers }}
{{- if has "windsurf" .supports }}
{{- if not $first }},{{ end }}
{{- $first = false }}
    "{{ .name }}": {
{{- if and (hasKey . "url") (not (hasKey . "command")) }}
      "serverUrl": "{{ .url }}"
{{- else }}
      "command": "{{ .command }}",
      "args": [{{ range $i, $arg := .args }}{{ if $i }}, {{ end }}"{{ $arg }}"{{ end }}]
{{- end }}
{{- if hasKey . "env" }},
      "env": {
{{- $envFirst := true }}
{{- $opEnv := dict }}
{{- if hasKey . "op_env" }}{{ $opEnv = .op_env }}{{ end }}
{{- range $key, $value := .env }}
{{- if not $envFirst }},{{ end }}
{{- $envFirst = false }}
{{- $envValue := $value }}
{{- if and $opCmd (not $opReadFailed) (hasKey $opEnv $key) }}
{{- $secret := "" }}
{{- if eq $.chezmoi.os "windows" }}
{{- $secret = (output "pwsh" "-NoLogo" "-NoProfile" "-NonInteractive" "-Command" (printf "$ErrorActionPreference = 'SilentlyContinue'; $stdout = [System.IO.Path]::GetTempFileName(); $stderr = [System.IO.Path]::GetTempFileName(); try { $process = Start-Process -FilePath '%s' -ArgumentList @('read', '%s', '--account', '%s') -PassThru -WindowStyle Hidden -RedirectStandardOutput $stdout -RedirectStandardError $stderr; if ($process.WaitForExit(%d000) -and $process.ExitCode -eq 0) { Get-Content -LiteralPath $stdout -Raw -ErrorAction SilentlyContinue } else { Stop-Process -Id $process.Id -Force -ErrorAction SilentlyContinue } } finally { Remove-Item -LiteralPath $stdout, $stderr -Force -ErrorAction SilentlyContinue }; exit 0" $opCmd (index $opEnv $key) $.op_account_personal $opReadTimeoutSeconds) | trim) }}
{{- else }}
{{- $secret = (output "sh" "-c" (printf "( '%s' read '%s' --account '%s' 2>/dev/null ) & pid=$!; ( sleep %d; kill \"$pid\" 2>/dev/null ) & watcher=$!; if wait \"$pid\"; then kill \"$watcher\" 2>/dev/null; fi || true" $opCmd (index $opEnv $key) $.op_account_personal $opReadTimeoutSeconds) | trim) }}
{{- end }}
{{- if $secret }}{{ $envValue = $secret }}{{ else }}{{ $opReadFailed = true }}{{ end }}
{{- end }}
        "{{ $key }}": "{{ $envValue }}"
{{- end }}
      }
{{- end }}
    }
{{- end }}
{{- end }}
{{- end }}
  }
}
