# Set identity via local chezmoi data (not committed):
# ~/.config/chezmoi/chezmoi.toml
# [data.git]
#   name = "Your Name"
#   email = "you@example.com"
#   signingkey = "~/.ssh/signing_key.pub"
[user]
{{- $git := (get . "git" | default (dict)) }}
  name = {{ get $git "name" | default "YOUR_GIT_NAME" }}
  email = {{ get $git "email" | default "your.email@example.com" }}
  signingkey = {{ get $git "signingkey" | default "~/.ssh/signing_key.pub" }}

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
{{- if eq .chezmoi.os "windows" }}
  program = C:/Program Files/1Password/app/8/op-ssh-sign.exe
{{- else if eq .chezmoi.os "darwin" }}
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- else }}
  program = /opt/1Password/op-ssh-sign
{{- end }}

[safe]
  directory = *

[core]
  editor = nvim
{{- if eq .chezmoi.os "windows" }}
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- else }}
  sshCommand = ssh
{{- end }}

{{- if ne .chezmoi.os "windows" }}
[credential "https://github.com"]
  helper = "!gh auth git-credential"
[credential "https://gist.github.com"]
  helper = "!gh auth git-credential"
{{- end }}
