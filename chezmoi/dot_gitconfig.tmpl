# Identity source: chezmoi/.chezmoidata/personal.yaml (git.personal / git.work).
# Work identity is loaded via [includeIf "hasconfig:remote.*.url:git@github-work:**/**"]
# below when a repo's remote points at the github-work SSH host alias.
{{- $git := (get . "git" | default (dict)) }}
{{- $personal := (get $git "personal" | default (dict)) }}
[user]
  name = {{ get $personal "name" | default "YOUR_GIT_NAME" | quote }}
  email = {{ get $personal "email" | default "your.email@example.com" | quote }}
  signingkey = {{ get $personal "signingkey" | default "~/.ssh/signing_key.pub" | quote }}

{{- $isWSL := and (eq .chezmoi.os "linux") (contains "microsoft" (lower .chezmoi.kernel.osrelease)) }}
[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
{{- if eq .chezmoi.os "windows" }}
  program = C:/Program Files/1Password/app/8/op-ssh-sign.exe
{{- else if eq .chezmoi.os "darwin" }}
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- else if $isWSL }}
  # WSL: native Linux 1Password isn't installed and the Windows
  # op-ssh-sign.exe has interop quirks (ignores positional payload,
  # rejects Linux pubkey paths). The wrapper bridges those gaps.
  program = ~/.local/bin/op-ssh-sign-wsl
{{- else }}
  program = /opt/1Password/op-ssh-sign
{{- end }}

[core]
  editor = nvim
{{- if eq .chezmoi.os "windows" }}
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- else }}
  sshCommand = ssh
{{- end }}

{{- if ne .chezmoi.os "windows" }}
[credential "https://github.com"]
  helper = "!gh auth git-credential"
[credential "https://gist.github.com"]
  helper = "!gh auth git-credential"
{{- end }}

# Work identity override: matches remotes that use the github-work SSH host
# alias (defined in ~/.ssh/config). The override file is generated by
# chezmoi/dot_gitconfig-work.tmpl.
[includeIf "hasconfig:remote.*.url:git@github-work:**/**"]
  path = ~/.gitconfig-work

{{- if ne .chezmoi.os "windows" }}
[alias]
  gtr = "!f() { [ -z \"$1\" ] && echo 'Usage: git gtr <branch>' && return 1; root=$(git worktree list --porcelain | grep '^worktree ' | head -1 | sed 's/^worktree //'); git worktree add \"$root/.worktrees/$1\" \"$1\"; }; f"
{{- end }}

{{- if eq .chezmoi.os "windows" }}
[safe]
  directory = D:/ruru/dotfiles
{{- end }}

[ghq]
{{- if eq .chezmoi.os "windows" }}
  root = D:/my_programing
  root = D:/ruru
{{- else }}
  root = ~/ghq
{{- end }}
